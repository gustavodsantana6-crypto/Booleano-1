import os
os.system ("cls || clear")


# Entrada de dados (Quantidade em Kg)
kg_morango = float(input("Digite a quantidade de morangos (Kg): "))
kg_maca = float(input("Digite a quantidade de maçãs (Kg): "))

# Definição dos preços por faixa de peso
if kg_morango <= 5:
    preco_morango = 2.50
else:
    preco_morango = 2.20

if kg_maca <= 5:
    preco_maca = 1.80
else:
    preco_maca = 1.50

# Cálculos iniciais
valor_morango = kg_morango * preco_morango
valor_maca = kg_maca * preco_maca

peso_total = kg_morango + kg_maca
valor_total = valor_morango + valor_maca

# Verificação do desconto de 10%
# Condição: Mais de 10kg no total OU valor acima de R$ 15,00
if peso_total > 10 or valor_total > 15:
    desconto = valor_total * 0.10
    valor_final = valor_total - desconto
    print(f"Desconto aplicado! Você economizou R$ {desconto:.2f}")
else:
    valor_final = valor_total

# Exibição do resultado
print("-" * 30)
print(f"Resumo da compra:")
print(f"Peso total: {peso_total:.2g} Kg")
print(f"Valor a pagar: R$ {valor_final:.2f}")